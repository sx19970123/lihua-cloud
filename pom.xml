<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>com.lihua</groupId>
    <artifactId>lihua</artifactId>
    <version>2.0.2</version>
    <packaging>pom</packaging>

    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>4.0.5</version>
        <relativePath/>
    </parent>

    <properties>
        <maven.compiler.source>25</maven.compiler.source>
        <maven.compiler.target>25</maven.compiler.target>

        <version>2.0.2</version>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <mysql.version>8.2.0</mysql.version>
        <mybatis-plus.version>3.5.16</mybatis-plus.version>
        <jwt.version>4.5.1</jwt.version>
        <redisson.version>4.2.0</redisson.version>
        <caffeine.version>3.2.3</caffeine.version>
        <oshi.version>6.6.4</oshi.version>
        <tianai-captcha.version>1.5.5</tianai-captcha.version>
        <ipaddress.version>5.5.1</ipaddress.version>
        <ip2region.version>3.2.0</ip2region.version>
        <dynamic-datasource.version>4.5.0</dynamic-datasource.version>
        <fesod.version>2.0.1-incubating</fesod.version>
        <oss.version>3.18.5</oss.version>
        <spring-doc.version>3.0.2</spring-doc.version>
        <snail-job.version>1.10.0-beta1</snail-job.version>
    </properties>

    <dependencyManagement>
        <dependencies>
<!--            业务依赖=============================================-->
            <dependency>
                <groupId>com.lihua</groupId>
                <artifactId>lihua-biz</artifactId>
                <version>${version}</version>
            </dependency>
<!--            系统监控 -->
            <dependency>
                <groupId>com.lihua</groupId>
                <artifactId>lihua-monitor</artifactId>
                <version>${version}</version>
            </dependency>
<!--            系统业务 -->
            <dependency>
                <groupId>com.lihua</groupId>
                <artifactId>lihua-system</artifactId>
                <version>${version}</version>
            </dependency>

<!--            基础依赖=============================================-->
<!--            公共模块 -->
            <dependency>
                <groupId>com.lihua</groupId>
                <artifactId>lihua-common</artifactId>
                <version>${version}</version>
            </dependency>
<!--            字典模块 -->
            <dependency>
                <groupId>com.lihua</groupId>
                <artifactId>lihua-dict</artifactId>
                <version>${version}</version>
            </dependency>
<!--            文档模块 -->
            <dependency>
                <groupId>com.lihua</groupId>
                <artifactId>lihua-doc</artifactId>
                <version>${version}</version>
            </dependency>
<!--            excel导入导出模块 -->
            <dependency>
                <groupId>com.lihua</groupId>
                <artifactId>lihua-excel</artifactId>
                <version>${version}</version>
            </dependency>
<!--            ip处理模块 -->
            <dependency>
                <groupId>com.lihua</groupId>
                <artifactId>lihua-ip</artifactId>
                <version>${version}</version>
            </dependency>
<!--            日志模块 -->
            <dependency>
                <groupId>com.lihua</groupId>
                <artifactId>lihua-log</artifactId>
                <version>${version}</version>
            </dependency>
<!--            mybatis持久层模块 -->
            <dependency>
                <groupId>com.lihua</groupId>
                <artifactId>lihua-mybatis</artifactId>
                <version>${version}</version>
            </dependency>
<!--            缓存模块 -->
            <dependency>
                <groupId>com.lihua</groupId>
                <artifactId>lihua-cache</artifactId>
                <version>${version}</version>
            </dependency>
<!--            安全模块 -->
            <dependency>
                <groupId>com.lihua</groupId>
                <artifactId>lihua-security</artifactId>
                <version>${version}</version>
            </dependency>
<!--            数据脱敏模块 -->
            <dependency>
                <groupId>com.lihua</groupId>
                <artifactId>lihua-sensitive</artifactId>
                <version>${version}</version>
            </dependency>
<!--            websocket模块 -->
            <dependency>
                <groupId>com.lihua</groupId>
                <artifactId>lihua-websocket</artifactId>
                <version>${version}</version>
            </dependency>
            <!--            web模块 -->
            <dependency>
                <groupId>com.lihua</groupId>
                <artifactId>lihua-web</artifactId>
                <version>${version}</version>
            </dependency>
<!--            验证码模块 -->
            <dependency>
                <groupId>com.lihua</groupId>
                <artifactId>lihua-captcha</artifactId>
                <version>${version}</version>
            </dependency>
<!--            定时任务模块 -->
            <dependency>
                <groupId>com.lihua</groupId>
                <artifactId>lihua-job</artifactId>
                <version>${version}</version>
            </dependency>
<!--            附件模块 -->
            <dependency>
                <groupId>com.lihua</groupId>
                <artifactId>lihua-attachment</artifactId>
                <version>${version}</version>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <dependencies>
        <!--        aop-->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-aspectj</artifactId>
        </dependency>
        <!--        lombok-->
        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
        </dependency>
        <!--         web-->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-webmvc</artifactId>
        </dependency>
        <!--        mysql-->
        <dependency>
            <groupId>com.mysql</groupId>
            <artifactId>mysql-connector-j</artifactId>
            <version>${mysql.version}</version>
        </dependency>
    </dependencies>

    <modules>
        <module>lihua-base</module>
        <module>lihua-biz</module>
    </modules>
    <build>
        <plugins>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
                <version>4.0.5</version>
                <configuration>
                    <classifier>exec</classifier>
                    <finalName>${project.artifactId}</finalName>
                    <mainClass>com.lihua.com.lihua.LiHuaAuthApplication</mainClass>
                </configuration>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.15.0</version>
                <configuration>
                    <compilerArgs>
                        <arg>-parameters</arg>
                    </compilerArgs>
                    <annotationProcessorPaths>
                        <path>
                            <groupId>org.projectlombok</groupId>
                            <artifactId>lombok</artifactId>
                        </path>
                    </annotationProcessorPaths>
                </configuration>
            </plugin>
        </plugins>
<!--        指定打包后包含的文件-->
        <resources>
            <resource>
                <directory>src/main/resources</directory>
                <includes>
                    <include>**/*.properties</include>
                    <include>**/*.xml</include>
                    <include>**/*.yml</include>
                    <include>**/*.txt</include>
                    <include>META-INF/services/*</include>
                    <include>META-INF/spring/*</include>
                    <include>captcha-images/**</include>
                    <include>captcha-font/**</include>
                    <include>ip2region/**</include>
                </includes>
            </resource>
            <resource>
                <directory>src/main/java</directory>
                <includes>
                    <include>**/*.properties</include>
                    <include>**/*.xml</include>
                </includes>
            </resource>
        </resources>
    </build>
</project>