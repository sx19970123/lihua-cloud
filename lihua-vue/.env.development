# 开发环境
VITE_APP_BASE_API = '/dev-api'

# websocket API前缀
VITE_APP_WS_API = '/ws-connect'

# 公共附件前缀（默认为后台服务接口，可根据实际需求替换为【域名】或【oss endpoint】）
VITE_APP_PUBLIC_ATTACHMENT_API = '/dev-api/system/attachment/storage/download/p?fullPath='